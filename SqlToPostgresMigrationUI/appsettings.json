{
  "ConnectionStrings": {
    "SqlServer": "Server=localhost;Database=SourceDB;Trusted_Connection=True;MultipleActiveResultSets=true;Command Timeout=300;",
    "Postgres": "Host=localhost;Database=TargetDB;Username=postgres;Password=;Timeout=300;"
  },
  "MigrationOptions": {
    "MaxParallelTables": 4,
    "BatchSize": 10000,
    "MaxRetries": 3,
    "RetryDelaySeconds": 5,
    "StateFilePath": "migration-state/state.json",
    "ValidateData": true,
    "DryRun": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "SqlToPostgresMigrationUI": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
